# seed-hunter — example environment configuration
#
# Copy this file to `.env` and source it (or use `dotenv`-style tooling) to
# set defaults without typing flags every time. Any flag passed on the
# command line always wins over the env value.
#
# Only the variables documented here are read by seed-hunter; everything
# else is configured exclusively through CLI flags.

# Path to the SQLite database. Created if it does not exist.
SEEDHUNTER_DB=./seed-hunter.db

# Path to a 2048-word BIP-39 wordlist file (one word per line, UTF-8). Leave
# unset to use the canonical English BIP-39 wordlist that is embedded in the
# binary at build time.
#
# To use a different language, point this at the corresponding official
# BIP-39 wordlist file (e.g. spanish.txt) from:
#   https://github.com/bitcoin/bips/tree/master/bip-0039
#
# Custom non-BIP-39 wordlists are accepted as long as they contain exactly
# 2048 unique non-empty lines, but they will produce zero valid checksums —
# useful only as a "what does the iterator do?" demo.
SEEDHUNTER_WORDLIST=

# 12-word BIP-39 starting mnemonic. Leave unset to have seed-hunter generate
# a freshly random demo seed at startup (recommended for first runs).
#
# Example (the canonical BIP-39 test vector — DO NOT FUND):
# SEEDHUNTER_TEMPLATE="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"
SEEDHUNTER_TEMPLATE=

# Balance API to query: "mempool" or "blockstream".
SEEDHUNTER_API=mempool

# Address script type: "segwit" (BIP-84, bc1...) or "legacy" (BIP-44, 1...).
SEEDHUNTER_SCRIPT_TYPE=segwit
